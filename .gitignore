# Only track these three top-level folders
/*
!/.gitignore
!/H_case/
!/Hodge_Decomposition/
!/Persistent_Homology/

# Common ignores within tracked folders
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual envs
.venv/
.venv*/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
.vscode/
.idea/
.claude/

# Testing / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# Logs
*.log

# Data folders (saved/cached files, not tracked)
Persistent_Homology/data/
Hodge_Decomposition/hodge-slugging/data/

# Pickle/cache artifacts anywhere in PH and HD trees
Persistent_Homology/**/*.pkl
Hodge_Decomposition/**/*.pkl
Persistent_Homology/**/*.joblib
Hodge_Decomposition/**/*.joblib
Persistent_Homology/**/*.npy
Hodge_Decomposition/**/*.npy
Persistent_Homology/**/*.npz
Hodge_Decomposition/**/*.npz
